@article{Vansteenkiste2016,
abstract = {In car driving, hazard perception tests have revealed important differences in perceptual-cognitive skills between novice and experienced drivers. Although these insights have led to new educational programs for learner drivers, similar research has not yet been done for other road users such as bicyclists. In the current investigation, a first hazard perception test for bicyclists has been developed and tested on both adults and children of ±eight year old. The test consisted of three sections in which visual behaviour, environmental awareness, and risk perception were evaluated respectively. Although only few differences in visual behaviour and environmental awareness were found, adults were found to react earlier on hazards than children. These results suggest that children have difficulties to interpret the necessary information to react timely to hazardous traffic situations. Alternatively, the current set-up of the hazard perception test might not have been suitable to detect differences in visual behaviour between children and adults in traffic situations. Therefore the development and use of future hazard perception tests for bicyclists is discussed.},
author = {Vansteenkiste, Pieter and Zeuwts, Linus and Cardon, Greet and Lenoir, Matthieu},
doi = {10.1016/j.trf.2016.05.001},
file = {:C\:/Users/LUCP10362/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/Vansteenkiste et al. - 2016 - A hazard-perception test for cycling children An exploratory study(3).pdf:pdf},
issn = {13698478},
journal = {Transportation Research Part F: Traffic Psychology and Behaviour},
keywords = {Children,Cycling,Hazard perception,Traffic safety},
pages = {182--194},
publisher = {Elsevier Ltd},
title = {{A hazard-perception test for cycling children: An exploratory study}},
url = {http://dx.doi.org/10.1016/j.trf.2016.05.001},
volume = {41},
year = {2016}
}
