issn = {20724292},
journal = {Remote Sensing 2021, Vol. 13, Page 4027},
keywords = {UAV image,deep learning,image segmentation,object detection,object tracking,traffic monitoring},
month = {oct},
number = {20},
pages = {4027},
publisher = {Multidisciplinary Digital Publishing Institute},
title = {{Road Traffic Monitoring from UAV Images Using Deep Learning Networks}},
url = {https://www.mdpi.com/2072-4292/13/20/4027/htm https://www.mdpi.com/2072-4292/13/20/4027},
volume = {13},
year = {2021}
}
