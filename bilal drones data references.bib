@article{ARNBERGER2002,
abstract = {National parks in close proximity to large conurbations are not subject to the normal conflicts between conservation and ecological tourism but to those between conservation and urban recreational requirements. The Danube Floodplains National Park, Lower Austria is situated to the east of Vienna, the capital city of Austria, with a population of 1.6 million. Between June 2000 and May 2001, visitors were monitored in the Lower Austrian part of the National Park. An analysis of the results of the interviews, as well as their integration with the results obtained using long-term video monitoring, counts by human observers and route analysis, led to the identification of specific visitor categories with individual behavioral patterns and spatio-temporal distribution. In particular, regular recreational visitors from adjacent residential areas were very concerned about overcrowding and would react to the high visitor frequency through a change in their habits. This alteration of visiting habits would lead to grave problems for the environmental management of the National Park.},
author = {ARNBERGER, Arne and BRANDENBURG, Christiane},
file = {:C\:/Users/LUCP10362/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/ARNBERGER, BRANDENBURG - 2002 - Visitor Structure of a Heavily Used Conservation Area The Danube Floodplains National Park , Lower Aust.pdf:pdf},
journal = {Monitoring and Management of Visitor Flows in Recreational and Protected Areas},
pages = {7--13},
title = {{Visitor Structure of a Heavily Used Conservation Area : The Danube Floodplains National Park , Lower Austria}},
year = {2002}
}
@article{Nerg2012,
abstract = {This study examines the impacts of socio-demographic, economic and park quality determinants on visits to nature areas. The authors apply panel data estimation techniques to Finnish data on 46 national parks and hiking areas between 2000 and 2008. The main results show that 'visits to nature areas', as a variable, reacts positively to the population size and quality features but negatively to gasoline prices and income level. Of the age classes, the population share of 'young retirees' - people aged between 65 and 74 - increased the number of visits to nature areas significantly, whereas the share of 'baby boomers' - people aged between 55 and 64 - was insignificant in explaining the number of visits. As the baby boomers are reaching retirement age, and assuming that their generation behaves like the young retirees in this study, the demand for national parks and hiking areas may increase substantially in the coming years. This will increase the pressure to expand current parks and establish new ones.},
author = {Nerg, Anna and Uusivuori, Jussi and Mikkola, Jarmo and Neuvonen, Marjo and Siev{\"{a}}nen, Tuija},
doi = {10.5367/te.2012.0104},
file = {:C\:/Users/LUCP10362/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/Nerg et al. - 2012 - Visits to national parks and hiking areas A panel data analysis of their sociodemographic, economic and site qualit.pdf:pdf},
issn = {13548166},
journal = {Tourism Economics},
keywords = {Fixed effects model,National parks,Nature areas,Panel data},
number = {1},
pages = {77--93},
title = {{Visits to national parks and hiking areas: A panel data analysis of their sociodemographic, economic and site quality determinants}},
volume = {18},
year = {2012}
}
@article{Thapa2012,
abstract = {Wildlife and natural amenities are major attractions at Kafue National Park (KNP) in Zambia. Although there has been an increase in visitation over the past few years, the current volume is low compared with its size and slightly skewed towards domestic visitors. The objective of this study was to examine what prevents visitation to KNP. Based on the adaptation of the leisure constraints model, this study examined structural constraints between international and domestic visitors in Zambia. On-site intercept surveys were conducted at two international airports and accommodations in various regions of the country. International visitors were more likely to perceive personal structural constraints (i.e. fear of personal safety, not enough time, and the lack of interest with travel companion or group) and environmental structural constraints (i.e. not enough quality lodges and camps, lack of available information about the park and unsuitable weather conditions). Domestic visitors were more likely to perceive financial cost and poor road conditions. Results of site-specific structural constraints provide planning and marketing implications which can be utilised by the Zambian Wildlife Authority and Tourism Board. {\textcopyright} 2012 Copyright Taylor and Francis Group, LLC.},
author = {Thapa, Brijesh},
doi = {10.1080/14724049.2011.647918},
file = {:C\:/Users/LUCP10362/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/Thapa - 2012 - Why did they not visit Examining structural constraints to visit Kafue National Park, Zambia.pdf:pdf},
issn = {14724049},
journal = {Journal of Ecotourism},
keywords = {Africa,Kafue National Park,National Parks,Zambia,constraints,tourists},
number = {1},
pages = {74--83},
title = {{Why did they not visit? Examining structural constraints to visit Kafue National Park, Zambia}},
volume = {11},
year = {2012}
}
@article{Rossi2015,
abstract = {There is a sizable literature about the factors shaping park visitation and use - especially for urban parks, including (i) geographic (e.g. proximity), (ii) socio-cultural (e.g. population characteristics) and to a lesser extent, (iii) individual psychometric factors (e.g. attitudes and values). Yet comparatively little is known about how factors related to distance may affect peri-urban national park use, particularly outside the United States. This paper reports on research investigating distance-related factors affecting use of a peri-urban national park in Brisbane, Australia. This study found that older visitors live closer to the park while younger visitors travel further to use it. Surprisingly, travel distance did not vary with the type of recreational activities that users were conducting in the park. These results have implications for park planning and management including user demand for different recreational activities in peri-urban national parks. Results are useful for scholars using distance decay models to explain travel behaviour, evidencing the empirical veracity of the model in different places and across different service types. The findings are especially important for geographers because they demonstrate that assumptions about uniform park catchments may be unsupported and need to be empirically validated.},
author = {Rossi, Sebastian Dario and Byrne, Jason Antony and Pickering, Catherine Marina},
doi = {10.1016/j.apgeog.2015.06.008},
file = {:C\:/Users/LUCP10362/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/Rossi, Byrne, Pickering - 2015 - The role of distance in peri-urban national park use Who visits them and how far do they travel.pdf:pdf},
issn = {01436228},
journal = {Applied Geography},
keywords = {Distance decay,Gravity model,Park use,Travel patterns,Urban-rural fringe,Visitor},
pages = {77--88},
publisher = {Elsevier Ltd},
title = {{The role of distance in peri-urban national park use: Who visits them and how far do they travel?}},
url = {http://dx.doi.org/10.1016/j.apgeog.2015.06.008},
volume = {63},
year = {2015}
}
@article{Lumsdon2006,
abstract = {The paper explores the design of tourism bus networks at destinations. It analyzes the findings from indepth interviews with 51 practitioners currently involved in the provision of buses for tourism purposes in the United Kingdom. The study suggests that a more comprehensive approach to such buses needs to be grounded in market understanding and accounting for the differences between utility and recreational trips. It argues that the tourist seeks a tourism experience and that this should be integral to the design of bus provision in order to encourage a modal shift from the private car. A model derived from the review of the literature and fieldwork is presented. {\textcopyright} 2006 Elsevier Ltd. All rights reserved.},
