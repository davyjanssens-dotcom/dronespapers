isbn = {9781479908820},
issn = {21512191},
journal = {International Conference Image and Vision Computing New Zealand},
keywords = {machine vision,object recognition,supervised learning,vehicle detection,vehicle safety},
pages = {35--40},
title = {{Machine vision techniques for motorcycle safety helmet detection}},
year = {2013}
}
