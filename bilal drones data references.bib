pmid = {39000823},
publisher = {Multidisciplinary Digital Publishing Institute},
title = {{HeMoDU: High-Efficiency Multi-Object Detection Algorithm for Unmanned Aerial Vehicles on Urban Roads}},
url = {https://www.mdpi.com/1424-8220/24/13/4045/htm https://www.mdpi.com/1424-8220/24/13/4045},
volume = {24},
