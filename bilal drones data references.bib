pmid = {17174259},
title = {{An examination of the environmental attributes associated with pedestrian-vehicular crashes near public schools.}},
volume = {39},
year = {2007}
}
@article{Madana2020,
abstract = {The world is currently moving forward in a faster technological advancements, innovations and researches. This has helped in improving the lives of mankind to a wider perspective. Latest technologies in drones and various sensors have helped in various object-detection methods fulfilling the necessary requirements. Drones are widely used in today's world for many purposes. This include capturing live data as live monitoring systems which are being used by the police or military forces in safeguarding and protecting the areas under their control. Hence it is used as surveillance device. It is also used by event management teams for capturing photo and videos of the function like marriages, stage shows and so on. This paper focuses on improvements in accident detection and reporting methods so as to ensure faster, accurate and less human intervened or human less accident reporting model and hence proposes an algorithm for implementing the model so as to make the accident reporting without the need for police man to be available in the accident scene hence making the system fully autonomous. This will in fact make the accident reporting system more hassle-free and easier for the police and also for the victim who is part of an accident as there is no need for making calls to report accidents to the police and also no need for the presence of a physical policeman at the accident spot.},
