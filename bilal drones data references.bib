@article{Al-Fadhli2014,
abstract = {The RECON project is an unmanned aerial vehicle (UAV), which is automated to monitor, analyze, inspect, and intervene in bridges, roads, residential areas, etc. RECON is controlled using data acquisition devices from National Instruments and programmed under LabVIEW. The system is prepared to make a stable journey, communicate, deliver, and intervene and assist. RECON is ubiquitous; the software is web-enabled so that the user can control it using smart phones, tablets, laptops and other computing devices. The system provides a true pervasive computing experience. This paper presents the system organization, architecture, programming application, evaluation and analysis of the proposed system.},
